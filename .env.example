# BookCatalog Environment Configuration
#
# Copy to .env and fill in your values.

# OpenAI API key (required for LLM-powered title extraction, future feature)
OPENAI_API_KEY=sk-your-key-here

# OpenAI model for book title extraction (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Path to local Open Library SQLite database (optional, auto-detected)
# OPENLIBRARY_DB_PATH=data/openlibrary/openlibrary.db
